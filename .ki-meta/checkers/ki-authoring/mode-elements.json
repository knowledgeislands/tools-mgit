{
  "version": 1,
  "elements": [
    {
      "id": "authoring-inspection",
      "mode": "audit",
      "phase": "inspect",
      "entry": "scripts/audit.ts",
      "reads": ["Markdown", "authoring-config"],
      "writes": []
    },
    {
      "id": "authoring-config",
      "mode": "conform",
      "phase": "prepare",
      "entry": "scripts/conform.ts",
      "reads": [".prettierrc.json", ".editorconfig", ".markdownlint-cli2.jsonc"],
      "writes": [".prettierrc.json", ".editorconfig", ".markdownlint-cli2.jsonc"]
    },
    {
      "id": "markdown-normalise",
      "mode": "conform",
      "phase": "normalise",
      "entry": "scripts/conform.ts",
      "after": ["authoring-config"],
      "reads": ["Markdown", ".prettierrc.json", ".markdownlint-cli2.jsonc"],
      "writes": ["Markdown"]
    }
  ]
}
