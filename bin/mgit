#!/usr/bin/env bash
# shellcheck disable=SC2088  # literal '~' in .mgitconfig path strings is intentional, not tilde expansion
# shellcheck disable=SC2016  # backticks inside single-quoted generated-comment strings are literal
# Run a command across multiple git repositories.
#
# Terminology: a repository has either a standard structure (a checkout with a
# .git directory) or a nested structure (a .bare store, a .git controller file,
# and a main/ checkout). Container dirs are the directories between the
# cwd and repository roots. The repo set comes from a
# .mgitconfig in the current directory if one exists; otherwise the tree is
# walked for .git entries (dropping any nested under another repo).
#
# A .mgitconfig holds two kinds of lines:
#
#     <path>               a member: a child container dir, or a child repo
#                          (relative to the file's dir, or ~-prefixed / absolute)
#     <link>  ->  <target> a symlink a repo owns, pointing into another repo
#
# `mgit register` writes a .mgitconfig in every container dir (listing its
# children) and in every leaf dir that owns cross-repo symlinks (listing them).
# It stops at leaf dirs — it never descends into a repo — and always scans
# fresh, ignoring existing config (so it implies -I).
#
# At runtime mgit walks that hierarchy: container members are recursed into,
# repo members are operated on, and the repo containing each symlink target is
# pulled in too (transitive, with cycle/dup guards). git already tracks the
# symlinks themselves, so they come back on clone; mgit only records them.
#
# '#' comments and blank lines are ignored.

MGIT_CONFIG=.mgitconfig
MGIT_VERSION=0.4.1

CLEAR=$'\033[0m'
BOLD=$'\033[1m'
YELLOW=$'\033[33m'

usage() {
  cat <<'EOF'
Usage: mgit [options] [command]
       mgit [options] register
       mgit structure <standard|nested> <--dry-run|--yes>
       mgit worktree <list|status|add|remove> [options]
       mgit completion <bash|zsh>

Runs supplied command on multiple git repositories.

A "leaf dir" has a .git child (a repo); "container dirs" are the directories
between the cwd and the leaf dirs. The repo set comes from ./.mgitconfig if
present, else by walking the tree. A .mgitconfig holds two kinds of lines:
  <path>               a member: a child container dir, or a child repo
  <link>  ->  <target>  a symlink a repo owns, into another git repo

Options:
  -P, --physical         Don't follow symlinked container dirs (default)
  -L, --follow-symlinks  Follow symlinked container dirs (never symlinked repos)
  -B, --bare             Run bare; don't prefix command with git
  -I, --ignore           Ignore .mgitconfig files; walk the tree instead
  -h, --help             Show this message
  -V, --version          Print version and exit

Subcommand:
  register               Write a .mgitconfig in every container dir (listing its
                         child containers/repos) and in every leaf dir that owns
                         cross-repo symlinks (listing them). Stops at leaf dirs,
                         never descending into a repo. Always scans fresh
                         (implies -I) and overwrites generated files.
  worktree list           List worktrees, grouped by shared Git store.
  worktree status         Show branch and cleanliness for every working tree.
  structure nested        Convert eligible standard repos to nested structure.
  structure standard      Convert eligible nested repos to standard structure.
  worktree add BRANCH     Add BRANCH from origin to every structured repo in the set.
  worktree remove PATH    Remove a linked worktree; requires --yes.
  completion SHELL       Print completion setup for bash or zsh.
EOF
}

completion_script() {
  case "${1:-}" in
    bash)
      cat <<'EOF'
_mgit() {
  local cur="${COMP_WORDS[COMP_CWORD]}" command subcommand
  command="${COMP_WORDS[1]:-}"
  subcommand="${COMP_WORDS[2]:-}"
  case "$command" in
    structure)
      COMPREPLY=( $(compgen -W 'standard nested --dry-run --yes --help' -- "$cur") )
      ;;
    worktree)
      case "$subcommand" in
        '') COMPREPLY=( $(compgen -W 'list status add remove' -- "$cur") ) ;;
        add) COMPREPLY=() ;;
        remove) COMPREPLY=( $(compgen -W '--yes --force --help' -- "$cur") ) ;;
        *) COMPREPLY=() ;;
      esac
      ;;
    completion)
      COMPREPLY=( $(compgen -W 'bash zsh' -- "$cur") )
      ;;
    *)
      COMPREPLY=( $(compgen -W 'register structure worktree completion -P --physical -L --follow-symlinks -B --bare -I --ignore -h --help -V --version' -- "$cur") )
      ;;
  esac
}
complete -F _mgit mgit
EOF
      ;;
    zsh)
      cat <<'EOF'
#compdef mgit

_mgit() {
  local -a global_commands global_options
  global_commands=(
    'register:generate .mgitconfig manifests'
    'structure:change repository structure across the current set'
    'worktree:manage standard and nested worktrees'
    'completion:print shell completion setup'
  )
  global_options=(
    '-P[do not follow symlinked container directories]'
    '--physical[do not follow symlinked container directories]'
    '-L[follow symlinked container directories]'
    '--follow-symlinks[follow symlinked container directories]'
    '-B[run command without git prefix]'
    '--bare[run command without git prefix]'
    '-I[ignore .mgitconfig files]'
    '--ignore[ignore .mgitconfig files]'
    '-h[show help]'
    '--help[show help]'
    '-V[show version]'
    '--version[show version]'
  )
  case $words[2] in
    structure) _arguments '1:repository structure:(standard nested)' '--dry-run[preview changes]' '--yes[confirm changes]' ;;
    worktree)
      case $words[3] in
        '') _describe -t commands 'worktree command' 'list:list worktrees' 'status:show worktree status' 'add:add a remote branch' 'remove:remove a worktree' ;;
        add) _message 'remote branch name' ;;
        remove) _arguments '--yes[confirm removal]' '--force[discard dirty changes]' ;;
      esac ;;
    completion) _arguments '1:shell:(bash zsh)' ;;
    *) _arguments -s $global_options '1:command:_describe -t commands command global_commands' ;;
  esac
}

_mgit "$@"
EOF
      ;;
    *)
      printf 'mgit completion: expected bash or zsh\n' >&2
      return 2
      ;;
  esac
}

# Trim leading/trailing whitespace.
trim() {
  local s="$1"
  s="${s#"${s%%[![:space:]]*}"}"
  s="${s%"${s##*[![:space:]]}"}"
  printf '%s' "$s"
}

# Canonical absolute path of a directory (resolves symlinks and ..); empty on
# failure.
canon_dir() { ( cd "$1" 2>/dev/null && pwd -P ); }

# Resolve $1 (absolute, ~-prefixed, or relative to base dir $2) to an
# absolute-ish path. May still contain .. components.
resolve_path() {
  local p="$1" base="$2"
  case "$p" in
    "~")   p="$HOME" ;;
    "~/"*) p="$HOME/${p#\~/}" ;;
  esac
  case "$p" in
    /*) printf '%s' "$p" ;;
    *)  printf '%s/%s' "$base" "$p" ;;
  esac
}

# Canonical absolute path of any existing path (dir or file/symlink leaf).
canon_any() {
  local p="$1" d b
  if [ -d "$p" ]; then canon_dir "$p"; return; fi
  d=$(dirname "$p"); b=$(basename "$p")
  d=$(canon_dir "$d") || return 1
  [ -z "$d" ] && return 1
  printf '%s/%s' "$d" "$b"
}

# Git-aware repository predicates.  A linked worktree has a .git *file*, so
# filesystem tests alone cannot describe the repository model.  Git owns that
# distinction and also tells us whether a directory is a bare repository.
is_worktree() {
  [ "$(git -C "$1" rev-parse --is-inside-work-tree 2>/dev/null)" = true ]
}

is_bare_repo() {
  [ "$(git -C "$1" rev-parse --is-bare-repository 2>/dev/null)" = true ]
}

is_repo() {
  is_worktree "$1" || is_bare_repo "$1"
}

# A nested repository is deliberately stricter than an arbitrary Git worktree.
# Its outer directory is a controller, .bare is the common Git store, and every
# live checkout (including main) lives directly below that controller.
is_nested_repo() {
  local root="$1" bare path
  root=$(canon_dir "$root") || return 1
  bare=$(canon_dir "$root/.bare") || return 1
  [ -f "$root/.git" ] && [ -d "$bare" ] && [ -d "$root/main" ] || return 1
  is_bare_repo "$root" || return 1
  is_worktree "$root/main" || return 1
  [ "$(git_common_dir "$root/main")" = "$bare" ] || return 1
  while IFS= read -r path; do
    [ -z "$path" ] && continue
    case "$path" in
      "$bare"|"$root"/*) ;;
      *) return 1 ;;
    esac
  done < <(git -C "$root" worktree list --porcelain 2>/dev/null | sed -n 's/^worktree //p')
}

repo_type() {
  if is_nested_repo "$1"; then
    printf 'nested'
  elif [ -d "$1/.git" ] && is_worktree "$1"; then
    printf 'standard'
  elif is_bare_repo "$1"; then
    printf 'bare'
  else
    printf 'unknown'
  fi
}

active_worktree_paths() {
  local root="$1" path state
  path=""; state=""
  while IFS= read -r line || [ -n "$line" ]; do
    if [ -z "$line" ]; then
      [ -n "$path" ] && [ "$state" != prunable ] && [ "$state" != bare ] && printf '%s\n' "$path"
      path=""; state=""
      continue
    fi
    case "$line" in
      "worktree "*) path="${line#worktree }" ;;
      prunable*)    state=prunable ;;
      bare)         state=bare ;;
    esac
  done < <(git -C "$root" worktree list --porcelain 2>/dev/null)
  [ -n "$path" ] && [ "$state" != prunable ] && [ "$state" != bare ] && printf '%s\n' "$path"
}

# A repository has two useful identities: its checkout (if any) and the common
# Git directory shared by all of its linked worktrees.  Keep them distinct so
# commands can operate on checkouts while grouping by their shared store.
git_common_dir() {
  local dir="$1" common
  common=$(git -C "$dir" rev-parse --git-common-dir 2>/dev/null) || return 1
  case "$common" in
    /*) canon_dir "$common" ;;
    *)  canon_dir "$dir/$common" ;;
  esac
}

git_dir() {
  local dir="$1" gitdir
  gitdir=$(git -C "$dir" rev-parse --git-dir 2>/dev/null) || return 1
  case "$gitdir" in
    /*) canon_dir "$gitdir" ;;
    *)  canon_dir "$dir/$gitdir" ;;
  esac
}

# Print the canonical directory of the Git repository containing path $1.  Git
# handles .git directories, linked-worktree .git files, and bare repositories.
repo_of() {
  local p="$1" d root
  if [ -d "$p" ]; then d="$p"; else d="${p%/*}"; [ "$d" = "$p" ] && d="."; fi
  d=$(canon_dir "$d") || return 1
  [ -z "$d" ] && return 1
  while :; do
    root=$(git -C "$d" rev-parse --show-toplevel 2>/dev/null)
    if [ -n "$root" ]; then canon_dir "$root"; return; fi
    is_bare_repo "$d" && { printf '%s' "$d"; return 0; }
    [ "$d" = "/" ] && return 1
    d="${d%/*}"; [ -z "$d" ] && d="/"
  done
}

# Return the nested structure containing $1, if any. A command issued from a
# child checkout must still resolve to the outer workspace controller.
structure_of() {
  local p="$1" d
  if [ -d "$p" ]; then d="$p"; else d="${p%/*}"; [ "$d" = "$p" ] && d="."; fi
  d=$(canon_dir "$d") || return 1
  while :; do
    is_nested_repo "$d" && { printf '%s' "$d"; return 0; }
    [ "$d" = "/" ] && return 1
    d="${d%/*}"; [ -z "$d" ] && d="/"
  done
}

# Relative path from dir $1 to path $2 (both absolute & canonical).
relpath() {
  local from="${1%/}" to="${2%/}" i j n m min rel="" down=""
  local fa ta IFS=/
  read -ra fa <<< "${from#/}"
  read -ra ta <<< "${to#/}"
  unset IFS
  n=${#fa[@]}; m=${#ta[@]}; min=$n; [ "$m" -lt "$n" ] && min=$m
  i=0
  while [ "$i" -lt "$min" ] && [ "${fa[$i]}" = "${ta[$i]}" ]; do i=$((i + 1)); done
  j=$i; while [ "$j" -lt "$n" ]; do rel="../$rel"; j=$((j + 1)); done
  j=$i; while [ "$j" -lt "$m" ]; do down="$down${ta[$j]}/"; j=$((j + 1)); done
  rel="$rel$down"; rel="${rel%/}"
  [ -z "$rel" ] && rel="."
  printf '%s' "$rel"
}

# Pick how to express target $2 in repo $1's .mgitconfig: relative to the repo
# for nearby targets, ~-prefixed or absolute for ones living far out of tree.
choose_target() {
  local repoabs="$1" tabs="$2" rel
  rel=$(relpath "$repoabs" "$tabs")
  case "$rel" in
    ../../*)
      case "$tabs" in
        "$HOME"/*) printf '~/%s' "${tabs#"$HOME"/}" ;;
        *)         printf '%s' "$tabs" ;;
      esac ;;
    *) printf '%s' "$rel" ;;
  esac
}

# Parse dir $1's .mgitconfig, emitting one TAB-separated record per declaration:
#   S|N|B|D<TAB><path>      standard, nested, bare, or directory member
#   R<TAB><path>            legacy untyped member
#   L<TAB><link><TAB><tgt>  a symlink declaration
parse_mgit() {
  local repo="$1" line link target
  [ -f "$repo/$MGIT_CONFIG" ] || return 0
  while IFS= read -r line || [ -n "$line" ]; do
    line="${line%%#*}"
    line=$(trim "$line")
    [ -z "$line" ] && continue
    case "$line" in
      *"->"*)
        link=$(trim "${line%%->*}")
        target=$(trim "${line#*->}")
        if [ -z "$link" ] || [ -z "$target" ]; then
          printf 'mgit: %s: malformed symlink line: %s\n' "$repo/$MGIT_CONFIG" "$line" >&2
          continue
        fi
        printf 'L\t%s\t%s\n' "$link" "$target"
        ;;
      *)
        case "$line" in
          "standard "*)  printf 'S\t%s\n' "${line#standard }" ;;
          "nested "*)    printf 'N\t%s\n' "${line#nested }" ;;
          "bare "*)      printf 'B\t%s\n' "${line#bare }" ;;
          "dir "*)       printf 'D\t%s\n' "${line#dir }" ;;
          *)              printf 'R\t%s\n' "$line" ;;
        esac
        ;;
    esac
  done < "$repo/$MGIT_CONFIG"
}

# Expand a ~ prefix; leave absolute/relative paths untouched.
expand_tilde() {
  case "$1" in
    "~")   printf '%s' "$HOME" ;;
    "~/"*) printf '%s/%s' "$HOME" "${1#\~/}" ;;
    *)     printf '%s' "$1" ;;
  esac
}

# register, repo case: scan dir $1 for symlinks into *other* git repos and write
# its .mgitconfig (symlink lines only). Removes a stale config if none are found.
#
# Heavy directories that never hold intentional cross-repo links (.git itself,
# node_modules) are pruned from the scan. Symlinks resolving back inside this
# repo — the overwhelming majority, e.g. node_modules/.bin/* — are skipped with
# a cheap string check, so the expensive repo lookup only runs for the few links
# that actually escape the repo.
register_repo() {
  local dir="$1" repoabs sl slabs tabs trepo i l width
  local found_links=() found_targets=()
  repoabs=$(canon_dir "$dir") || return 0
  [ -z "$repoabs" ] && return 0
  while IFS= read -r sl; do
    sl="${sl#./}"
    [ -z "$sl" ] && continue
    git -C "$dir" check-ignore -q "$sl" 2>/dev/null && continue  # gitignored = ephemeral, skip
    slabs="$dir/$sl"
    tabs=$(canon_any "$slabs") || continue
    [ -z "$tabs" ] && continue
    case "$tabs" in "$repoabs"/*) continue ;; esac  # internal link: skip cheaply
    trepo=$(repo_of "$tabs")
    [ -z "$trepo" ] && continue                     # target not in a git repo
    found_links+=("$sl")
    found_targets+=("$(choose_target "$repoabs" "$tabs")")
  done < <(cd "$dir" && find . \( -name .git -o -name node_modules \) -prune \
             -o -type l -print 2>/dev/null | sort)

  if [ ${#found_links[@]} -eq 0 ]; then
    [ -f "$dir/$MGIT_CONFIG" ] && rm -f "$dir/$MGIT_CONFIG"
    return 0
  fi
  width=0
  for l in "${found_links[@]}"; do [ ${#l} -gt "$width" ] && width=${#l}; done
  {
    printf '# .mgitconfig — generated by `mgit register`. "<link> -> <target>" is a\n'
    printf '# symlink this repo owns, recorded so mgit pulls in the linked repo.\n'
    for i in "${!found_links[@]}"; do
      printf '%-*s -> %s\n' "$width" "${found_links[$i]}" "${found_targets[$i]}"
    done
  } > "$dir/$MGIT_CONFIG"
  printf '%s%s%s%s: recorded %d symlink(s)\n' "$BOLD" "$YELLOW" "$dir" "$CLEAR" "${#found_links[@]}"
  return 0
}

# register, recursive: write a .mgitconfig in every container dir (and every
# leaf dir that owns symlinks). Returns 0 if $1 is or contains a repo (so its
# parent should reference it), 1 otherwise.
reg_seen=()
reg_is_seen() {
  local needle="$1" x
  for x in "${reg_seen[@]+"${reg_seen[@]}"}"; do
    [ "$x" = "$needle" ] && return 0
  done
  return 1
}
register_tree() {
  local dir="$1" child kids=() k canon kind child_kind
  # In -L mode, guard against symlink cycles by canonical path.
  if [ "$follow_symlinks" = true ]; then
    canon=$(canon_dir "$dir") || return 1
    reg_is_seen "$canon" && return 1
    reg_seen+=("$canon")
  fi
  kind=$(repo_type "$dir")
  if [ "$kind" != unknown ]; then
    # A nested structure and a bare store are leaf repository units. A standard
    # checkout alone may own cross-repository symlinks to record.
    [ "$kind" = standard ] && register_repo "$dir"
    return 0
  fi
  for child in "$dir"/*/; do
    [ -d "$child" ] || continue          # no subdirs (glob didn't match)
    child="${child%/}"
    if [ -L "$child" ]; then
      # Follow symlinked dirs only in -L mode, and only container dirs — a
      # symlinked leaf repo is skipped (it's an alias of a real repo).
      [ "$follow_symlinks" = true ] || continue
      [ "$(repo_type "$child")" != unknown ] && continue
    fi
    child_kind=$(repo_type "$child")
    if [ "$child_kind" != unknown ]; then
      register_tree "$child" || return 1
      kids+=("$child_kind $(basename "$child")")
    elif register_tree "$child"; then
      kids+=("dir $(basename "$child")")
    fi
  done
  if [ ${#kids[@]} -gt 0 ]; then
    {
      printf '# mgit config (generated by `mgit register`).\n'
      printf '# standard/nested/bare PATH = repository structure; dir PATH = directory.\n'
      printf '# Structure labels are refreshed by register; Git remains the runtime source of truth.\n'
      for k in "${kids[@]}"; do printf '%s\n' "$k"; done
    } > "$dir/$MGIT_CONFIG"
    printf '%s%s%s%s: recorded %d member(s)\n' "$BOLD" "$YELLOW" "$dir" "$CLEAR" "${#kids[@]}"
    return 0
  fi
  [ -f "$dir/$MGIT_CONFIG" ] && rm -f "$dir/$MGIT_CONFIG"
  return 1
}

worktree_paths=()
worktree_commons=()
worktree_heads=()
worktree_branches=()
worktree_states=()
worktree_seen_commons=()

worktree_common_seen() {
  local needle="$1" item
  for item in "${worktree_seen_commons[@]+"${worktree_seen_commons[@]}"}"; do
    [ "$item" = "$needle" ] && return 0
  done
  return 1
}

worktree_add_record() {
  worktree_paths+=("$1")
  worktree_commons+=("$2")
  worktree_heads+=("$3")
  worktree_branches+=("$4")
  worktree_states+=("$5")
}

# Populate records for every worktree attached to the supplied repositories.
# The common directory is deliberately de-duplicated: each linked checkout can
# be discovered independently, but represents the same Git repository.
collect_worktrees() {
  local source common source_type line key value path head branch state
  worktree_paths=()
  worktree_commons=()
  worktree_heads=()
  worktree_branches=()
  worktree_states=()
  worktree_seen_commons=()

  for source in "$@"; do
    common=$(git_common_dir "$source") || continue
    worktree_common_seen "$common" && continue
    worktree_seen_commons+=("$common")
    source_type=$(repo_type "$source")
    path=""; head=""; branch=""; state=""
    while IFS= read -r line || [ -n "$line" ]; do
      if [ -z "$line" ]; then
        if [ -n "$path" ] && { [ "$source_type" != nested ] || [ "$path" != "$common" ]; }; then
          worktree_add_record "$path" "$common" "$head" "$branch" "${state:-normal}"
        fi
        path=""; head=""; branch=""; state=""
        continue
      fi
      key=${line%% *}
      value=${line#* }
      case "$key" in
        worktree) path="$value" ;;
        HEAD)     head="$value" ;;
        branch)   branch="${value#refs/heads/}" ;;
        detached) state="${state:+$state,}detached" ;;
        bare)     state="${state:+$state,}bare" ;;
        prunable) state="${state:+$state,}prunable" ;;
        locked)   state="${state:+$state,}locked" ;;
      esac
    done < <(git -C "$source" worktree list --porcelain 2>/dev/null)
    if [ -n "$path" ] && { [ "$source_type" != nested ] || [ "$path" != "$common" ]; }; then
      worktree_add_record "$path" "$common" "$head" "$branch" "${state:-normal}"
    fi
  done
}

display_worktree_path() {
  local path="$1" canonical
  canonical=$(canon_dir "$path")
  if [ -n "$canonical" ]; then
    disp "$canonical"
  elif [ "${path#/}" != "$path" ]; then
    # `git worktree list` retains an absolute record for a missing checkout;
    # it is still safe to make that lexical path relative to the current tree.
    relpath "$cwd_canon" "$path"
  else
    printf '%s' "$path"
  fi
}

worktree_list() {
  local i previous_common="" common
  collect_worktrees "${repo_units[@]+"${repo_units[@]}"}"
  for i in "${!worktree_paths[@]}"; do
    common="${worktree_commons[$i]}"
    if [ "$common" != "$previous_common" ]; then
      printf 'common-dir: %s\n' "$common"
      previous_common="$common"
    fi
    printf '  %s\t%s\t%s\n' "$(display_worktree_path "${worktree_paths[$i]}")" \
      "${worktree_branches[$i]:-(detached)}" "${worktree_states[$i]}"
  done
}

worktree_status() {
  local i path state status
  collect_worktrees "${repo_units[@]+"${repo_units[@]}"}"
  for i in "${!worktree_paths[@]}"; do
    path="${worktree_paths[$i]}"
    state="${worktree_states[$i]}"
    if [ ! -d "$path" ]; then
      printf '%s\t%s\tmissing (%s)\n' "$(display_worktree_path "$path")" \
        "${worktree_branches[$i]:-(detached)}" "$state"
      continue
    fi
    case "$state" in
      *bare*)
        printf '%s\t%s\tbare store\n' "$(display_worktree_path "$path")" \
          "${worktree_branches[$i]:-(detached)}"
        continue ;;
    esac
    status=$(git -C "$path" status --porcelain 2>/dev/null)
    if [ -n "$status" ]; then state="dirty"; else state="clean"; fi
    printf '%s\t%s\t%s\n' "$(display_worktree_path "$path")" \
      "${worktree_branches[$i]:-(detached)}" "$state"
  done
}

standard_root_of() {
  local source="$1" path common gitdir
  common=$(git_common_dir "$source") || return 1
  while IFS= read -r path; do
    [ -n "$path" ] || continue
    gitdir=$(git_dir "$path") || continue
    [ "$gitdir" = "$common" ] && { canon_dir "$path"; return 0; }
  done < <(active_worktree_paths "$source")
  return 1
}

worktree_source_repo() {
  local source
  source=$(structure_of ".") || source=$(standard_root_of ".") || source=$(repo_of ".") || {
    printf 'mgit worktree: run this command from inside a Git repository\n' >&2
    return 1
  }
  printf '%s' "$source"
}

valid_worktree_name() {
  case "$1" in
    ""|.|..|*/*|*\\*|*[!A-Za-z0-9._-]*) return 1 ;;
    *) return 0 ;;
  esac
}

worktree_default_path() {
  local source="$1" name="$2" parent base
  case "$(repo_type "$source")" in
    nested) printf '%s/%s' "$source" "$name" ;;
    standard)
      parent=$(dirname "$source")
      base=$(basename "$source")
      printf '%s/%s-%s' "$parent" "$base" "$name" ;;
    *) return 1 ;;
  esac
}

worktree_add() {
  local branch="${1:-}" unit root kind destination count=0 failed=false
  [ $# -eq 1 ] || { printf 'mgit worktree add: BRANCH is required\n' >&2; return 2; }
  valid_worktree_name "${branch//\//-}" || {
    printf 'mgit worktree add: invalid branch name: %s\n' "$branch" >&2
    return 2
  }

  # Preflight every structured repository before creating any worktree. This
  # avoids a typo or an already-checked-out branch leaving a partial set.
  for unit in "${repo_units[@]+"${repo_units[@]}"}"; do
    root=$(canon_dir "$unit") || continue
    kind=$(repo_type "$root")
    case "$kind" in standard|nested) ;; *) continue ;; esac
    count=$((count + 1))
    destination=$(worktree_default_path "$root" "${branch//\//-}") || continue
    [ ! -e "$destination" ] || {
      printf 'mgit worktree add: destination already exists: %s\n' "$destination" >&2
      failed=true
    }
    git -C "$root" show-ref --verify --quiet "refs/heads/$branch" || \
      git -C "$root" show-ref --verify --quiet "refs/remotes/origin/$branch" || {
        printf 'mgit worktree add: branch not found locally or at origin: %s (%s)\n' "$branch" "$root" >&2
        failed=true
      }
  done
  [ "$count" -gt 0 ] || { printf 'mgit worktree add: no standard or nested repositories in the current set\n' >&2; return 1; }
  [ "$failed" = false ] || return 1

  for unit in "${repo_units[@]+"${repo_units[@]}"}"; do
    root=$(canon_dir "$unit") || continue
    kind=$(repo_type "$root")
    case "$kind" in standard|nested) ;; *) continue ;; esac
    destination=$(worktree_default_path "$root" "${branch//\//-}") || continue
    if git -C "$root" show-ref --verify --quiet "refs/heads/$branch"; then
      git -C "$root" worktree add "$destination" "$branch" || return
    else
      git -C "$root" worktree add --track -b "$branch" "$destination" "origin/$branch" || return
    fi
    printf 'mgit: added %s at %s\n' "$branch" "$destination"
  done
}

worktree_remove() {
  local target="" force=false yes=false source source_kind canonical i found=false path gitdir common
  while [ $# -gt 0 ]; do
    case "$1" in
      --yes) yes=true ;;
      --force) force=true ;;
      -h|--help) usage; return 0 ;;
      -*) printf 'mgit worktree remove: unknown option: %s\n' "$1" >&2; return 2 ;;
      *)
        [ -z "$target" ] || { printf 'mgit worktree remove: only one PATH is allowed\n' >&2; return 2; }
        target="$1" ;;
    esac
    shift
  done
  [ -n "$target" ] || { printf 'mgit worktree remove: PATH is required\n' >&2; return 2; }
  [ "$yes" = true ] || {
    printf 'mgit worktree remove: refusing to remove without --yes\n' >&2
    return 2
  }
  source=$(worktree_source_repo) || return 1
  source_kind=$(repo_type "$source")
  case "$source_kind" in standard|nested) ;; *)
    printf 'mgit worktree remove: unsupported repository structure\n' >&2
    return 1
  esac
  canonical=$(canon_dir "$(resolve_path "$(expand_tilde "$target")" "$(pwd)")") || {
    printf 'mgit worktree remove: PATH is not an existing directory: %s\n' "$target" >&2
    return 1
  }
  collect_worktrees "$source"
  for i in "${!worktree_paths[@]}"; do
    path=$(canon_dir "${worktree_paths[$i]}")
    [ "$path" = "$canonical" ] || continue
    found=true
    break
  done
  [ "$found" = true ] || {
    printf 'mgit worktree remove: not a worktree of this repository: %s\n' "$target" >&2
    return 1
  }
  gitdir=$(git_dir "$canonical")
  common=$(git_common_dir "$canonical")
  [ "$source_kind" != nested ] || [ "$canonical" != "$(canon_dir "$source/main")" ] || {
    printf 'mgit worktree remove: refusing to remove the required main worktree\n' >&2
    return 1
  }
  [ "$gitdir" != "$common" ] || {
    printf 'mgit worktree remove: refusing to remove the primary working tree\n' >&2
    return 1
  }
  if [ "$force" = true ]; then
    git -C "$source" worktree remove --force "$canonical"
  else
    git -C "$source" worktree remove "$canonical"
  fi
}

conversion_branch() {
  git -C "$1" symbolic-ref --quiet --short HEAD 2>/dev/null
}

validate_nested_structure() {
  local root="$1" branch changes count
  [ "$(repo_type "$root")" = standard ] || return 1
  branch=$(conversion_branch "$root") || {
    printf 'mgit structure nested: skipping detached repository: %s\n' "$root" >&2
    return 1
  }
  changes=$(git -C "$root" status --porcelain) || return 1
  [ -z "$changes" ] || {
    printf 'mgit structure nested: skipping dirty repository: %s\n' "$root" >&2
    return 1
  }
  count=$(git -C "$root" worktree list --porcelain 2>/dev/null | awk '/^worktree / { n++ } END { print n + 0 }')
  [ "$count" -eq 1 ] || {
    printf 'mgit structure nested: skipping repository with linked worktrees: %s\n' "$root" >&2
    return 1
  }
  printf '%s' "$branch"
}

# Turn a clean standard checkout into the colocated mgit layout without deleting
# its former files. The original checkout is retained in .mgit-backup-<stamp>;
# a failed conversion restores its .git directory and leaves the failed attempt
# beside it for inspection.
structure_nested_repository() {
  local root="$1" branch="$2" parent name stamp stage failed backup
  parent=$(dirname "$root")
  name=$(basename "$root")
  stamp=$(date +%Y%m%d%H%M%S)
  stage="$parent/.${name}.mgit-nested-$stamp"
  failed="$parent/.${name}.mgit-failed-$stamp"
  backup="$root/.mgit-backup-$stamp"
  [ ! -e "$stage" ] && [ ! -e "$failed" ] || {
    printf 'mgit structure nested: staging path already exists for %s\n' "$root" >&2
    return 1
  }

  mv "$root" "$stage" || return 1
  if ! mkdir "$root" || ! mv "$stage/.git" "$root/.bare" || \
     ! git --git-dir="$root/.bare" config core.bare true || \
     ! printf 'gitdir: ./.bare\n' > "$root/.git" || \
     ! git -C "$root" worktree add main "$branch"; then
    printf 'mgit structure nested: conversion failed; restoring %s\n' "$root" >&2
    mv "$root" "$failed" 2>/dev/null || true
    [ -d "$failed/.bare" ] && mv "$failed/.bare" "$stage/.git" 2>/dev/null || true
    mv "$stage" "$root" 2>/dev/null || true
    printf 'mgit structure nested: failed attempt retained at %s\n' "$failed" >&2
    return 1
  fi
  if ! mv "$stage" "$backup"; then
    printf 'mgit structure nested: converted %s, but rollback backup remains at %s\n' "$root" "$stage" >&2
    return 1
  fi
  printf 'mgit: structured %s as nested (backup: %s)\n' "$root" "$backup"
}

structure_nested() {
  local mode="" unit root kind branch failed=false
  while [ $# -gt 0 ]; do
    case "$1" in
      --dry-run|--yes)
        [ -z "$mode" ] || { printf 'mgit structure nested: choose one of --dry-run or --yes\n' >&2; return 2; }
        mode="$1" ;;
      -h|--help) usage; return 0 ;;
      *) printf 'mgit structure nested: unexpected argument: %s\n' "$1" >&2; return 2 ;;
    esac
    shift
  done
  [ -n "$mode" ] || {
    printf 'mgit structure nested: use --dry-run to preview or --yes to change repositories\n' >&2
    return 2
  }
  for unit in "${repo_units[@]+"${repo_units[@]}"}"; do
    root=$(canon_dir "$unit") || continue
    kind=$(repo_type "$root")
    case "$kind" in
      nested) printf 'mgit structure nested: already nested: %s\n' "$root" ;;
      standard)
        branch=$(validate_nested_structure "$root") || { failed=true; continue; }
        if [ "$mode" = --dry-run ]; then
          printf 'mgit structure nested: would restructure %s (%s -> main/)\n' "$root" "$branch"
        else
          structure_nested_repository "$root" "$branch" || failed=true
        fi ;;
      bare) printf 'mgit structure nested: skipping bare repository: %s\n' "$root" >&2; failed=true ;;
      *) printf 'mgit structure nested: skipping unsupported path: %s\n' "$root" >&2; failed=true ;;
    esac
  done
  [ "$failed" = false ]
}

validate_standard_structure() {
  local root="$1" paths=() path changes
  [ "$(repo_type "$root")" = nested ] || return 1
  while IFS= read -r path; do [ -n "$path" ] && paths+=("$path"); done < <(active_worktree_paths "$root")
  [ ${#paths[@]} -eq 1 ] && [ "$(canon_dir "${paths[0]}")" = "$(canon_dir "$root/main")" ] || {
    printf 'mgit structure standard: skipping repository with non-main worktrees: %s\n' "$root" >&2
    return 1
  }
  changes=$(git -C "$root/main" status --porcelain) || return 1
  [ -z "$changes" ] || {
    printf 'mgit structure standard: skipping dirty main worktree: %s\n' "$root" >&2
    return 1
  }
}

structure_standard_repository() {
  local root="$1" parent name stamp stage backup
  parent=$(dirname "$root")
  name=$(basename "$root")
  stamp=$(date +%Y%m%d%H%M%S)
  stage="$parent/.${name}.mgit-standard-$stamp"
  backup="$parent/.${name}.mgit-nested-backup-$stamp"
  [ ! -e "$stage" ] || return 1
  mv "$root" "$stage" || return 1
  if ! mv "$stage/.git" "$stage/.mgit-controller" || \
     ! mv "$stage/.bare" "$stage/.git" || \
     ! git --git-dir="$stage/.git" config core.bare false || \
     ! mv "$stage/main" "$root" || \
     ! mv "$root/.git" "$stage/.mgit-main-gitfile" || \
     ! mv "$stage/.git" "$root/.git"; then
    printf 'mgit structure standard: conversion failed; retained staging path: %s\n' "$stage" >&2
    return 1
  fi
  mv "$stage" "$backup" || {
    printf 'mgit structure standard: converted %s, but backup remains at %s\n' "$root" "$stage" >&2
    return 1
  }
  printf 'mgit: structured %s as standard (backup: %s)\n' "$root" "$backup"
}

structure_standard() {
  local mode="" unit root kind failed=false
  while [ $# -gt 0 ]; do
    case "$1" in
      --dry-run|--yes) [ -z "$mode" ] || return 2; mode="$1" ;;
      -h|--help) usage; return 0 ;;
      *) printf 'mgit structure standard: unexpected argument: %s\n' "$1" >&2; return 2 ;;
    esac
    shift
  done
  [ -n "$mode" ] || { printf 'mgit structure standard: use --dry-run to preview or --yes to change repositories\n' >&2; return 2; }
  for unit in "${repo_units[@]+"${repo_units[@]}"}"; do
    root=$(canon_dir "$unit") || continue
    kind=$(repo_type "$root")
    case "$kind" in
      standard) printf 'mgit structure standard: already standard: %s\n' "$root" ;;
      nested)
        validate_standard_structure "$root" || { failed=true; continue; }
        if [ "$mode" = --dry-run ]; then
          printf 'mgit structure standard: would restructure %s (main/ -> repository root)\n' "$root"
        else
          structure_standard_repository "$root" || failed=true
        fi ;;
      *) printf 'mgit structure standard: skipping unsupported repository: %s\n' "$root" >&2; failed=true ;;
    esac
  done
  [ "$failed" = false ]
}

structure_command() {
  local target="${1:-}"
  [ $# -gt 0 ] && shift
  case "$target" in
    nested) structure_nested "$@" ;;
    standard) structure_standard "$@" ;;
    *) printf 'mgit structure: expected standard or nested\n' >&2; return 2 ;;
  esac
}

worktree_command() {
  local action="${1:-list}"
  [ $# -gt 0 ] && shift
  case "$action" in
    list)   [ $# -eq 0 ] || { printf 'mgit worktree list: unexpected argument\n' >&2; return 2; }; worktree_list ;;
    status) [ $# -eq 0 ] || { printf 'mgit worktree status: unexpected argument\n' >&2; return 2; }; worktree_status ;;
    add)    worktree_add "$@" ;;
    remove) worktree_remove "$@" ;;
    *) printf 'mgit worktree: expected list, status, add, or remove\n' >&2; return 2 ;;
  esac
}

follow_symlinks=false
bare=false
read_config=true

while [ $# -gt 0 ]; do
  case "$1" in
    -P|--physical)        follow_symlinks=false ;;
    -L|--follow-symlinks) follow_symlinks=true ;;
    -B|--bare)            bare=true ;;
    -I|--ignore)          read_config=false ;;
    -h|--help)            usage; exit 0 ;;
    -V|--version)         printf 'mgit %s\n' "$MGIT_VERSION"; exit 0 ;;
    --)                   shift; break ;;
    -*)                   printf 'mgit: unknown option: %s\n' "$1" >&2; usage >&2; exit 2 ;;
    *)                    break ;;
  esac
  shift
done

if [ "${1:-}" = "completion" ]; then
  shift
  completion_script "$@"
  exit $?
fi

# `register` is self-contained (it scans the filesystem), so handle it before
# building the repo set.
if [ "${1:-}" = "register" ]; then
  shift
  while [ $# -gt 0 ]; do
    case "$1" in
      -h|--help) usage; exit 0 ;;
      *) printf 'mgit register: unexpected argument: %s\n' "$1" >&2; exit 2 ;;
    esac
    # shellcheck disable=SC2317  # reachable once register grows an option that doesn't exit
    shift
  done
  if register_tree "."; then
    exit 0
  else
    printf 'mgit register: no git repos found under %s\n' "$(pwd)" >&2
    exit 1
  fi
fi

repos=()

# Base set: a ./.mgitconfig manifest pins it (typed or legacy member lines,
# plus the current dir itself if it's a repo); otherwise discover by walking.
if [ "$read_config" = true ] && [ -f "./$MGIT_CONFIG" ]; then
  while IFS=$'\t' read -r kind a b; do
    case "$kind" in S|N|B|D|R) repos+=("$(expand_tilde "$a")") ;; esac
  done < <(parse_mgit ".")
  [ "$(repo_type ".")" != unknown ] && repos+=(".")
else
  # Include the current directory itself when it is a repository.  In
  # particular, a bare store has no nested .git marker for `find` to discover.
  [ "$(repo_type ".")" != unknown ] && repos+=(".")
  if [ "$follow_symlinks" = true ]; then
    found=$(
      find -L . -name .git 2>/dev/null | sed -e 's:/\.git$::' -e 's:^\./::'
      find -L . -type d -name '*.git' -print 2>/dev/null
    )
  else
    found=$(
      find . -name .git 2>/dev/null | sed -e 's:/\.git$::' -e 's:^\./::'
      find . -type d -name '*.git' -print 2>/dev/null
    )
  fi
  found=$(printf '%s\n' "$found" | sed -e 's:^\./::' | sort -u)

  # Sorted order means any parent repository appears before its children, so a
  # prefix check against already-kept repos drops the nested ones.  The .git
  # marker candidates and `*.git` candidates are both verified by Git here.
  while IFS= read -r r; do
    [ -z "$r" ] && continue
    [ "$(repo_type "$r")" != unknown ] || continue
    nested=false
    for parent in "${repos[@]+"${repos[@]}"}"; do
      case "$r" in
        "$parent"/*) nested=true; break ;;
      esac
    done
    [ "$nested" = false ] && repos+=("$r")
  done <<< "$found"
fi

# Walk the hierarchy: typed and legacy member lines that are repos are operated
# on and member directories are recursed into; symlink (L) lines pull in the
# repo containing each target. Types are informative; Git verifies the live
# structure at runtime. Transitive, with cycle/dup guards. Every repo is
# displayed (and cd'd into) as a path relative to the cwd.
final=()
seen=()

is_seen() {
  local needle="$1" x
  for x in "${seen[@]+"${seen[@]}"}"; do
    [ "$x" = "$needle" ] && return 0
  done
  return 1
}

cwd_canon=$(canon_dir ".")
# Path of canonical dir $1 relative to the cwd (e.g. hnr/kit-hnr, ../other/repo).
disp() { relpath "$cwd_canon" "$1"; }

queue=()  # canonical dirs whose .mgitconfig still needs walking

# Seed from the base set, distinguishing repos (operate + walk) from grouping
# directories (walk only).
for r in "${repos[@]+"${repos[@]}"}"; do
  c=$(canon_dir "$r")
  if [ -z "$c" ]; then
    printf 'mgit: skipping (not a directory): %s\n' "$r" >&2
    continue
  fi
  is_seen "$c" && continue
  seen+=("$c"); queue+=("$c")
  [ "$(repo_type "$c")" != unknown ] && final+=("$(disp "$c")")
done

qi=0
while [ $qi -lt ${#queue[@]} ]; do
  repo="${queue[$qi]}"; qi=$((qi + 1))
  while IFS=$'\t' read -r kind a b; do
    case "$kind" in
      L)
        [ -z "$b" ] && continue
        add=$(repo_of "$(resolve_path "$b" "$repo")")
        if [ -z "$add" ]; then
          printf 'mgit: %s: symlink target not inside a git repo: %s\n' \
            "$repo/$MGIT_CONFIG" "$b" >&2
          continue
        fi
        is_seen "$add" && continue
        seen+=("$add"); queue+=("$add"); final+=("$(disp "$add")")  # target is a repo
        ;;
      S|N|B|D|R)
        [ -z "$a" ] && continue
        add=$(canon_dir "$(resolve_path "$(expand_tilde "$a")" "$repo")")
        if [ -z "$add" ]; then
          printf 'mgit: %s: member not found: %s\n' "$repo/$MGIT_CONFIG" "$a" >&2
          continue
        fi
        is_seen "$add" && continue
        seen+=("$add"); queue+=("$add")
        [ "$(repo_type "$add")" != unknown ] && final+=("$(disp "$add")")  # a repo member; dirs walk only
        ;;
    esac
  done < <(parse_mgit "$repo")
done

repo_units=("${final[@]+"${final[@]}"}")
repos=()
for r in "${repo_units[@]+"${repo_units[@]}"}"; do
  c=$(canon_dir "$r") || continue
  case "$(repo_type "$c")" in
    standard|nested)
      while IFS= read -r wt; do
        [ -z "$wt" ] && continue
        repos+=("$(disp "$(canon_dir "$wt")")")
      done < <(active_worktree_paths "$c")
      ;;
    bare) repos+=("$(disp "$c")") ;;
  esac
done

if [ "${1:-}" = "structure" ]; then
  shift
  structure_command "$@"
  exit $?
fi

# Worktree management is a first-class mgit command rather than a generic
# `git worktree` fan-out. It applies each operation according to the standard
# or nested structure of every repository in the current multi-repository set.
if [ "${1:-}" = "worktree" ]; then
  shift
  worktree_command "$@"
  exit $?
fi

if [ $# -eq 0 ]; then
  for r in "${repos[@]+"${repos[@]}"}"; do
    printf '%s\n' "$r"
  done
  exit 0
fi

printed_cmd=$(printf '%q ' "$@")
printed_cmd="${printed_cmd% }"

for d in "${repos[@]+"${repos[@]}"}"; do
  if [ "$bare" = true ]; then
    printf '%s%s%s%s: %s\n' "$BOLD" "$YELLOW" "$d" "$CLEAR" "$printed_cmd"
    ( cd "$d" && "$@" )
  else
    printf '%s%s%s%s: git %s\n' "$BOLD" "$YELLOW" "$d" "$CLEAR" "$printed_cmd"
    ( cd "$d" && git "$@" )
  fi
done
